# Copy this file to .env and fill in the values.

# Postgres connection string (e.g. from Vercel Postgres / Neon).
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Session signing secret. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=""

# Shared secret for POST /api/invoices/ingest (external systems like
# Make.com authenticate with this via the x-api-key header). Generate one
# with:
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
INVOICE_INGEST_API_KEY=""

# Base URL this app is reachable at, used to build the QuickBooks OAuth
# redirect URI (must exactly match a Redirect URI registered on the Intuit
# Developer app). No trailing slash.
APP_BASE_URL="http://localhost:3000"

# QuickBooks Online OAuth2 app credentials (developer.intuit.com -> your
# app -> Keys & OAuth). Used by /admin/reconcile to read Purchase
# transactions for payment matching. Never write access - read-only against
# the company's real books.
QUICKBOOKS_CLIENT_ID=""
QUICKBOOKS_CLIENT_SECRET=""
# "production" (default) or "sandbox"
QUICKBOOKS_ENVIRONMENT="production"
