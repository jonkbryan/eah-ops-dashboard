// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ---------------------------------------------------------------------------
// Core generic schema. No EAH-specific values live here — job/cost-code/user
// data is loaded separately via prisma/seed.ts so this schema is reusable for
// future clients.
// ---------------------------------------------------------------------------

model User {
  id               String   @id @default(cuid())
  name             String
  email            String   @unique
  passwordHash     String
  // A user can hold either or both roles (e.g. Eli/Phil hold both).
  isSuperintendent Boolean  @default(false)
  isAdmin          Boolean  @default(false)
  createdAt        DateTime @default(now())

  jobsSupervised   Job[]     @relation("JobSuperintendent")
  invoiceDecisions Invoice[] @relation("InvoiceDecidedBy")
  paymentsRecorded Payment[] @relation("PaymentRecordedBy")
}

model Job {
  id               String   @id @default(cuid())
  name             String
  address          String?
  status           String   @default("active")
  budgetCents      Int?
  superintendentId String?
  createdAt        DateTime @default(now())

  superintendent User?     @relation("JobSuperintendent", fields: [superintendentId], references: [id])
  invoices       Invoice[]
}

model CostCode {
  id       String    @id @default(cuid())
  code     String    @unique
  label    String
  invoices Invoice[]
}

model Vendor {
  id       String    @id @default(cuid())
  name     String    @unique
  invoices Invoice[]
}

model Invoice {
  id                   String    @id @default(cuid())
  vendorId             String
  jobId                String
  costCodeId           String
  amountCents          Int
  // pending -> approved | rejected | flagged -> paid
  status               String    @default("pending")
  note                 String?
  // Link to the invoice document (e.g. a Google Drive file). Just a URL for
  // now — not a file upload — see prisma/seed-data/eah.ts and the README for
  // why (EAH already has a Drive-based pipeline that owns the actual files).
  attachmentUrl        String?
  decisionNote         String?
  // Captured only when a superintendent approves (not on reject/flag) — a
  // base64 PNG data URL from the on-screen signature pad.
  approvalSignature    String?
  decidedById          String?
  decidedAt            DateTime?
  // Which upcoming Friday payment batch this approved invoice is slated
  // for. Scheduling metadata only — set before the invoice is actually
  // marked paid, doesn't change status.
  scheduledPaymentDate DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  job       Job       @relation(fields: [jobId], references: [id])
  costCode  CostCode  @relation(fields: [costCodeId], references: [id])
  vendor    Vendor    @relation(fields: [vendorId], references: [id])
  decidedBy User?     @relation("InvoiceDecidedBy", fields: [decidedById], references: [id])
  payments  Payment[]

  @@index([jobId])
  @@index([status])
  @@index([vendorId])
}

model Payment {
  id           String   @id @default(cuid())
  invoiceId    String
  amountCents  Int
  method       String
  paidAt       DateTime @default(now())
  recordedById String
  createdAt    DateTime @default(now())

  invoice    Invoice @relation(fields: [invoiceId], references: [id])
  recordedBy User    @relation("PaymentRecordedBy", fields: [recordedById], references: [id])

  @@index([invoiceId])
}
